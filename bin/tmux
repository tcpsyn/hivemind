#!/bin/bash
# Tmux proxy wrapper — forwards ALL calls to real tmux, then notifies Electron app

# Find real tmux binary
REAL_TMUX="${REAL_TMUX:-}"
if [ -z "$REAL_TMUX" ]; then
  for p in /opt/homebrew/bin/tmux /usr/local/bin/tmux /usr/bin/tmux; do
    if [ -x "$p" ]; then
      REAL_TMUX="$p"
      break
    fi
  done
fi

if [ -z "$REAL_TMUX" ] || [ ! -x "$REAL_TMUX" ]; then
  echo "tmux proxy: cannot find real tmux binary" >&2
  exit 1
fi

# Forward ALL arguments to real tmux using dedicated socket if set
if [ -n "$CC_TMUX_SOCKET" ]; then
  "$REAL_TMUX" -L "$CC_TMUX_SOCKET" "$@"
else
  "$REAL_TMUX" "$@"
fi
EXIT_CODE=$?

# Notify Electron app about interesting commands (fire-and-forget)
if [ -n "$CC_FRONTEND_SOCKET" ] && [ -S "$CC_FRONTEND_SOCKET" ]; then
  CMD="${1:-}"
  case "$CMD" in
    new-session|new-window|split-window|send-keys|kill-pane|kill-session|kill-window)
      # Build JSON and send in background (doesn't block tmux return)
      (
        # Build JSON array from args using jq (no python3 dependency)
        ARGS_JSON=$(printf '%s\n' "$@" | jq -R -s 'split("\n") | .[:-1]' 2>/dev/null)
        if [ -n "$ARGS_JSON" ]; then
          printf '{"event":"tmux-command","command":"%s","args":%s,"exitCode":%d}\n' \
            "$CMD" "$ARGS_JSON" "$EXIT_CODE" | nc -U -w1 "$CC_FRONTEND_SOCKET" 2>/dev/null
        fi
      ) >/dev/null 2>&1 &
      ;;
  esac
fi

exit $EXIT_CODE
