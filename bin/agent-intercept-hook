#!/bin/bash
# PreToolUse hook: intercepts Agent tool calls and spawns them as tmux panes.
# Receives JSON on stdin from Claude Code hooks system.
# Exits 2 to block the Agent tool; stderr becomes Claude's feedback.

# Read JSON from stdin
INPUT=$(cat)

# Extract fields from tool_input
PROMPT=$(echo "$INPUT" | jq -r '.tool_input.prompt // empty')
DESCRIPTION=$(echo "$INPUT" | jq -r '.tool_input.description // "teammate"')
AGENT_TYPE=$(echo "$INPUT" | jq -r '.tool_input.subagent_type // empty')
TOOL_NAME=$(echo "$INPUT" | jq -r '.tool_name // empty')

# If no prompt, this isn't an agent-spawning call — let it through
if [ -z "$PROMPT" ]; then
  exit 0
fi

# Skip lightweight/read-only agents — they're fast and don't need a pane
case "${AGENT_TYPE}${TOOL_NAME}" in
  *Explore*|*Plan*|*claude-code-guide*)
    exit 0
    ;;
esac

# Require tmux socket to be set (means we're in a Hivemind session)
TMUX_CMD="${REAL_TMUX:-}"
TMUX_SOCKET="${CC_TMUX_SOCKET:-}"
TMUX_SESSION="${CC_TMUX_SESSION:-}"

if [ -z "$TMUX_CMD" ] || [ -z "$TMUX_SOCKET" ]; then
  exit 0
fi

# If no session name provided, discover it
if [ -z "$TMUX_SESSION" ]; then
  TMUX_SESSION=$("$TMUX_CMD" -L "$TMUX_SOCKET" list-sessions -F '#{session_name}' 2>/dev/null | head -1)
fi

# Write prompt to temp file (handles arbitrary content safely)
# macOS mktemp requires X's at end of template
PROMPT_FILE=$(mktemp /tmp/hivemind-agent-XXXXXXXX) || {
  echo "Error: Failed to create temp file for agent prompt" >&2
  exit 2
}
# Append reporting instructions as a footnote — the actual task comes first in $PROMPT
REPORT_INSTRUCTIONS="

(Note: When you finish the task above, call the hivemind_report_complete MCP tool with a summary of what you accomplished, then wait for further instructions.)"

printf '%s%s' "$PROMPT" "$REPORT_INSTRUCTIONS" > "$PROMPT_FILE"

# Create launcher script that pipes prompt via stdin to avoid ARG_MAX limits
LAUNCHER=$(mktemp /tmp/hivemind-launch-XXXXXXXX) || {
  echo "Error: Failed to create launcher script" >&2
  rm -f "$PROMPT_FILE"
  exit 2
}
cat > "$LAUNCHER" << 'LAUNCHER_EOF'
#!/bin/bash
PFILE="$1"
SELF="$0"
# Read prompt and pass as argument for interactive mode
# (-p would run in print mode and exit immediately)
PROMPT=$(cat "$PFILE")
rm -f "$PFILE" "$SELF"
exec claude "$PROMPT"
LAUNCHER_EOF
chmod +x "$LAUNCHER"

# Create a new tmux window for the teammate, targeting the session explicitly
TMUX_ERR=$(mktemp /tmp/hivemind-tmux-err-XXXXXXXX)
if [ -n "$TMUX_SESSION" ]; then
  PANE_ID=$("$TMUX_CMD" -L "$TMUX_SOCKET" new-window -t "${TMUX_SESSION}:" \
    -d -P -F '#{pane_id}' -n "$DESCRIPTION" "$LAUNCHER" "$PROMPT_FILE" 2>"$TMUX_ERR")
else
  PANE_ID=$("$TMUX_CMD" -L "$TMUX_SOCKET" new-window \
    -d -P -F '#{pane_id}' -n "$DESCRIPTION" "$LAUNCHER" "$PROMPT_FILE" 2>"$TMUX_ERR")
fi

if [ $? -ne 0 ] || [ -z "$PANE_ID" ]; then
  TMUX_ERROR=$(cat "$TMUX_ERR" 2>/dev/null)
  echo "Error: Failed to create tmux pane for teammate. tmux: ${TMUX_ERROR:-unknown error}. socket=$TMUX_SOCKET session=$TMUX_SESSION" >&2
  rm -f "$PROMPT_FILE" "$LAUNCHER" "$TMUX_ERR"
  exit 2
fi
rm -f "$TMUX_ERR"

# Set pane title to agent description
"$TMUX_CMD" -L "$TMUX_SOCKET" select-pane -t "$PANE_ID" -T "$DESCRIPTION" 2>/dev/null || true

# Tell lead agent the teammate was spawned (stderr -> Claude's feedback)
cat >&2 << FEEDBACK
Teammate agent spawned in Hivemind pane $PANE_ID.

CRITICAL — How to communicate with Hivemind teammates:
- hivemind_send_message(pane_id, message) — Send a task or message to a teammate
- hivemind_list_teammates() — List all teammates AND get any pending completion reports
- hivemind_check_teammate(pane_id) — View a teammate's recent terminal output

WORKFLOW: After sending tasks, you MUST call hivemind_list_teammates periodically (every 30-60 seconds) to check for teammate completion notifications. Teammates report back via this channel. Do NOT wait for the user to ask — proactively monitor your team.

Do NOT use SendMessage or the Agent tool — they will not reach Hivemind teammates.
FEEDBACK

exit 2
